    .light-theme .touch .btn-common-play-game-lg:active, 
    .light-theme .touch .btn-common-play-game-lg:focus, 
    .light-theme .touch .btn-common-play-game-lg:hover, 
    .light-theme .touch .btn-common-play-game-lg:visited, 
    .light-theme a.btn-common-play-game-lg {
        background-color: #02b757;
    }

    .light-theme .btn-primary-sm, 
    .light-theme .btn-primary-sm:hover,
    .light-theme .btn-growth-lg {
        border: none;
    }

    .light-theme .btn-primary-lg, 
    li.signup-button-container {
        border: 1px solid #02b757;
    }

    .light-theme .btn-growth-lg {
        display: inline-block;
        border-radius: 5px;
    }

    li.signup-button-container {
        border-radius: 3px;
    }

    .light-theme .btn-growth-md, 
    button.btn-primary-md.ng-binding[ng-click='chat\(\)'], 
    .light-theme .btn-primary-md.disabled, 
    .light-theme .btn-primary-md, 
    button.btn-common-play-game-lg.btn-primary-md {
        border-radius: 1px;
    }

    .dark-theme button.btn-common-play-game-lg.btn-primary-md:hover {
        background: #00bf5a;
    }

    /* Signup Submit */
    .signup-or-log-in .signup-container .signup-input-area .signup-submit-button {
        background-color: #02b757;
        border-color: #02b757;
        color: #fff;
        width: 100%;
        height: 50px;
        font-size: 20px;
    }

    /* Secondary Buttons */
    a.rbx-navbar-login.btn-secondary-sm.nav-menu-title.rbx-menu-item:hover {
        background: rgba(25,25,25,0.1);
        border: none;
        border-radius: 5px;
    }

    /* PAGE-SPECIFIC STYLES */

    /* Home Page */
    div.home-header-content a:before {
        content: "Hello, ";
    }

    div.home-header-content a:after {
        content: "!";
    }

    div[data-testid='home-page-game-grid'], 
    div.home-interleave-divider {
        display: var(--displayRecommended);
    }

    div.game-sort-carousel-wrapper:nth-of-type(3) {
        display: var(--displayTodaysPicks);
    }

    /* Profiles */
    .profile-header .header-caption .header-details .details-info li {
        display: unset;
        text-align: center;
        padding: 0 20px;
    }

    .profile-header .header-caption .header-details .details-info li .font-header-2 {
        font-size: 20px;
    }

    /* Header */
    .rbx-header .age-bracket-label .age-bracket-label-username,
    .rbx-header .age-bracket-label {
        visibility: hidden;
    }

    /* Chat & Dialogs */
    .chat-container.collapsed .chat-header .chat-header-title {
        color: #fff;
    }

    .light-theme .dialogs .dialog-container .dialog-message-container .indicated-message-bubble {
        color: rgb(116, 116, 116);
    }

    /* Game & Asset Cards */
    div.game-card-info, 
    span.playing-counts-label:before {
        content: title;
    }

    div.game-card-info, 
    span.playing-counts-label:after {
        content: " Playing";
    }

    .light-theme .game-card-container .game-card-thumb-container {
        background-color: transparent;
    }

    .game-card-container thumbnail-2d, 
    .game-card-thumb-container {
        height: 150px;
        width: 100%;
        display: inline-block;
        border-radius: 3px 3px 0 0;
    }

    span.thumbnail-2d-container.game-card-thumb-container > img, 
    div.featured-game-icon-container > span > img, 
    span.thumbnail-2d-container.game-card-thumb > img {
        padding: var(--iconPadding);
    }

    .game-card-container thumbnail-2d .game-card-thumb, 
    .game-card-thumb-container .game-card-thumb {
        width: 100%;
        border-radius: 0;
    }

    /* Store Cards */
    .light-theme .store-card {
        background-color: white;
