    }

    .dark-theme .builder-font .see-all-link-icon:after, 
    .builder-font.dark-theme .see-all-link-icon:after, 
    .builder-font.light-theme .see-all-link-icon:after, 
    .icon-push-right-sm, 
    .light-theme .builder-font .see-all-link-icon:after {
        display: none;
    }

    /* UI COMPONENTS */
    
    /* Scrollers */
    .light-theme .scroller {
        background-color: #ffffff;
        border: 1px solid #b8b8b8;
    }

    .light-theme .scroller:focus, 
    .light-theme .scroller:hover {
        background-color: #ffffff;
    }

    .light-theme .scroller.disabled {
        background-color: #f0f1f0;
        opacity: 1;
    }

    .dark-theme .scroller {
        transition: background-color .4s ease !important;
        background: #191b1dc4;
    }

    /* Avatars */
    .avatar-card-fullbody .avatar-card-image, 
    .avatar .avatar-card-image,
    .light-theme .avatar .avatar-card-image {
        width: 100%;
        height: 100%;
        word-break: break-all;
        vertical-align: top;
        background-color: #ffffff !important;
        border: 1px solid #b8b8b8;
    }

    .avatar.avatar-card-fullbody .avatar-status {
        background-color: transparent !important;
    }

    /* Slides & Panels */
    .slide-switcher .slide-item-container .slide-item-container-left .slide-item-image {
        box-shadow: 0 0 6px 0 rgba(0,0,0,0.49);
    }

    .light-theme .slide-switcher .slide-item-container .slide-item-container-right {
        color: rgb(25, 25, 25);
    }

    .light-theme .remove-panel {
        padding: 6px;
    }

    /* BUTTONS */

    /* Alert Buttons */
    .light-theme .btn-alert-md {
        background-color: #fff;
        border: 1px solid #b8b8b8;
        color: #191919;
        border-radius: 1px;
    }

    .light-theme .btn-alert-md:hover, 
    .light-theme .btn-alert-md:focus {
        background-color: #e30301;
        border: 1px solid #b8b8b8;
        color: #ffffff;
        border-radius: 1px;
    }

    /* Purchase & Growth Buttons */
    .light-theme .btn-buy-md:hover, 
    .light-theme .btn-buy-md:focus,
    .light-theme .btn-growth-lg:focus, 
    .light-theme .btn-growth-lg:hover, 
    .signup-or-log-in .signup-container .signup-input-area .signup-submit-button:hover, 
    li.signup-button-container:hover { 
        background-color: #3fc679;
        border-color: #3fc679;
        color: #fff;
        cursor: pointer;
    }

    .light-theme .btn-buy-md:hover, 
    .light-theme .btn-buy-md:focus {
        box-shadow: 0 1px 3px rgba(150,150,150,0.74);
    }

    /* Primary Buttons */
    .light-theme .btn-primary-sm, 
    .light-theme .btn-primary-sm:hover,
    .light-theme .btn-primary-lg, 
    li.signup-button-container,
    .light-theme .btn-growth-lg,
    .light-theme .btn-growth-md, 
    button.btn-primary-md.ng-binding[ng-click='chat\(\)'], 
    .light-theme .btn-primary-md.disabled, 
    .light-theme .btn-primary-md, 
